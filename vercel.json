{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/dw-1000", "destination": "/vi/products/dw-1000", "permanent": true },
    { "source": "/dw-1200", "destination": "/vi/products/dw-1200", "permanent": true },
    { "source": "/dw-1600", "destination": "/vi/products/dw-1600", "permanent": true },
    { "source": "/product-detail", "destination": "/vi/products/dw-1000", "permanent": true },
    { "source": "/compare", "destination": "/vi/products/compare", "permanent": true },
    { "source": "/products", "destination": "/vi/products", "permanent": true },
    { "source": "/products/:path*", "destination": "/vi/products/:path*", "permanent": true },
    { "source": "/en-product-detail", "destination": "/en/products/dw-1000", "permanent": true },
    { "source": "/blog", "destination": "/vi/blog", "permanent": true },
    { "source": "/blog/:path*", "destination": "/vi/blog/:path*", "permanent": true }
  ]
}
